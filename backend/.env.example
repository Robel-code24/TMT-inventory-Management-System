# Local SQLite (default — works without Supabase)
DATABASE_URL=sqlite:///./inventory.db

# For Supabase PostgreSQL, replace with:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

JWT_SECRET=change-me-to-a-long-random-secret-key-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# AI provider: openai or google
AI_PROVIDER=openai

# OpenAI API Key for AI Assistant
OPENAI_API_KEY=your-openai-api-key-here
# Optional: override the endpoint and model for routers like NoraRouter
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# For NoraRouter, set:
# OPENAI_API_BASE=https://router.bynara.id/v1
# OPENAI_MODEL=mistral-large

# Google Studio AI settings (free tier)
# Set AI_PROVIDER=google to use Google Studio instead of OpenAI
# GOOGLE_API_KEY=your-google-studio-api-key-here
# GOOGLE_API_BASE=https://generativelanguage.googleapis.com/v1beta2
# GOOGLE_MODEL=text-bison-001

# OpenRouter settings
# Set AI_PROVIDER=openrouter to use OpenRouter
# OPENROUTER_API_KEY=your-openrouter-api-key-here
# OPENROUTER_API_BASE=https://openrouter.ai/v1
# OPENROUTER_MODEL=gpt-4o-mini
